# =============================================================================
# NHISP - National Health Insurance Services Portal
# Environment Configuration (Example)
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL
POSTGRES_DB=nhisp_db
POSTGRES_USER=nhisp_user
POSTGRES_PASSWORD=nhisp_secret_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# PgAdmin (optional)
PGADMIN_DEFAULT_EMAIL=admin@nhisp.gov
PGADMIN_DEFAULT_PASSWORD=pgadmin_password
